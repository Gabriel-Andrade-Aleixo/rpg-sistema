    "sync:armors": "node scripts/sync-armors.js",
    "sync:spells": "node scripts/sync-divine-spells.js",
    "migrate:trello": "node scripts/migrate-trello-to-postgres.js",
    "audit:rules": "node scripts/audit-system-rules.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "adm-zip": "0.6.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0"
