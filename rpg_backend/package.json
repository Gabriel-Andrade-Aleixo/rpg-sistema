{
  "name": "rpg-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "check": "node --check server.js",
    "test": "node --test",
    "db:migrate": "node scripts/migrate-database.js",
    "sync:system": "node scripts/sync-system-catalog.js",
    "sync:rules": "node scripts/sync-rule-metadata.js",
