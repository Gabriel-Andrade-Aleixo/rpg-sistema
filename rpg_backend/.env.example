PORT=8787
# Vercel/serverless: use o Transaction Pooler do Supabase (porta 6543).
DATABASE_URL=postgresql://postgres.PROJECT_REF:senha@aws-0-regiao.pooler.supabase.com:6543/postgres
DATABASE_SSL=true
DATABASE_POOL_MAX=1
DATABASE_IDLE_TIMEOUT_MS=10000
PASSWORD_RESET_BASE_URL=http://localhost:3000
AUTH_EXPOSE_RESET_TOKEN=false
ALLOWED_ORIGINS=http://localhost:3000,https://seu-site.vercel.app
SESSION_DAYS=7

# Envio real de recuperação de senha. Configure em produção e mantenha fora do Git.
SMTP_HOST=smtp.seu-provedor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario@dominio.com
SMTP_PASS=sua-senha-ou-app-password
MAIL_FROM="Runalith RPG <usuario@dominio.com>"
